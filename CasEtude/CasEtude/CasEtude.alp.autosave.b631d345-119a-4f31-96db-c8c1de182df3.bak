			<DynamicEvents>
				<DynamicEventClass>
					<Id>1762962788284</Id>
					<Name><![CDATA[PatientTransitionEvent]]></Name>
					<X>90</X><Y>170</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[from]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[to]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[patient_id]]></Name>
						<Type><![CDATA[int]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[from_agent_type]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[from_agent_id]]></Name>
						<Type><![CDATA[int]]></Type>
					</Parameter>
					<Action><![CDATA[traceln("Patient transition from " + from + " to " + to + " at " + date());
//liberate agents
if(from_agent_type == "IOA") {
	c_IOA_patient_focus.set(from_agent_id,-1);
	if(c_IOA_queue.size() > 0) {
		c_IOA_patient_focus.set(from_agent_id,c_IOA_queue.pop());
		String next_station = p_patient_circuits.get(patient_id).get(c_patient_current_step.get(patient_id));
			create_PatientTransitionEvent(exponential(6),HOUR,"Triage IOA",next_station,c_IOA_patient_focus.get(from_agent_id),"IOA",
			from_agent_id); //
	}
}
if(to == "Triage IOA") {
	boolean agent_is_dispo = false;
	for(int i=0; i<c_IOA_patient_focus.size(); i++) {
		if(c_IOA_patient_focus.get(i) == -1) {
			agent_is_dispo = true;
			c_IOA_patient_focus.set(i,patient_id);
			String next_station = p_patient_circuits.get(patient_id).get(c_patient_current_step.get(patient_id));
			create_PatientTransitionEvent(exponential(6),HOUR,"Triage IOA",next_station,i,"IOA",i); //
		}
	}
	if(agent_is_dispo == false) {
		c_IOA_queue.addLast(patient_id);
	}
} // else c_patient_current_step.get(patient_id) ++
]]></Action>
				</DynamicEventClass>
			</DynamicEvents>
