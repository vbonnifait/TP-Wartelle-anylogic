	<Experiments>	
		<!--   =========   Simulation Experiment   ========  -->
		<SimulationExperiment ActiveObjectClassId="1762957837648">
			<Id>1762957837657</Id>
			<Name><![CDATA[Simulation]]></Name>
			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<InitialSetupCode><![CDATA[int NUMBER_OF_ARRIVALS = 500;
int MAX_NUMBER_OF_STEPS = 6;
// Init patient_circuits
for(int i=0; i<NUMBER_OF_ARRIVALS; i++) {
	c_patient_circuits.add(new ArrayList<String>(MAX_NUMBER_OF_STEPS));
	//traceln(patient_circuits.size());
	for(int j=0; j<MAX_NUMBER_OF_STEPS; j++) {
		c_patient_circuits.get(i).add("NA");
	}
}
// Headings
arrival_file.readString();
arrival_file.readString();
arrival_file.readString();

while(arrival_file.canReadMore()) {
	int case_id = Integer.parseInt(arrival_file.readString())-1;
	int activity_step = Integer.parseInt(arrival_file.readString())-1;
	String activity_name = arrival_file.readString();
	
	c_patient_circuits.get(case_id).set(activity_step,activity_name);
}
]]></InitialSetupCode>
			<MaximumMemory>512</MaximumMemory>
			<RandomNumberGenerationType>fixedSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<SeedValue>1</SeedValue>
			<SelectionModeForSimultaneousEvents>LIFO</SelectionModeForSimultaneousEvents>
			<VmArgs><![CDATA[]]></VmArgs>
			<LoadRootFromSnapshot>false</LoadRootFromSnapshot>
			<Variables>
				<Variable Class="CollectionVariable">
					<Id>1762958375558</Id>
					<Name><![CDATA[c_patient_circuits]]></Name>
					<X>70</X><Y>160</Y>
					<Label><X>10</X><Y>0</Y></Label>
