		<!--   =========   Active Object Class   ========  -->
		<ActiveObjectClass>
			<Id>1762957837648</Id>
			<Name><![CDATA[Main]]></Name>
			<StartupCode><![CDATA[Date current_time = date();
traceln(current_time.toString());

// creation of "agents"
c_IOA_patient_focus.add(-1);
c_MedCC_patient_focus.add(-1);
c_MedCL_patient_focus.add(-1);
c_Radiologue_patient_focus.add(-1);
c_Infirm_patient_focus.add(-1);

for(int i=0; i<p_patient_circuits.size(); i++) {
	c_patient_current_step.add(0);
	double current_arrival_rate = p_mean_arrival_rate;
	if(current_time.getHours() >= 12 && current_time.getHours() <= 18) {
		current_arrival_rate = p_mean_arrival_rate * 1.5;
	} else if(current_time.getHours() >= 0 && current_time.getHours() <= 6) {
		current_arrival_rate = p_mean_arrival_rate * 0.5;
	}
	Double delta_in_hours = exponential(current_arrival_rate);
	current_time.setTime((long) ((double)current_time.getTime() + delta_in_hours * 3600 * 1000));
	create_PatientTransitionEvent(current_time.getTime() - date().getTime(), MILLISECOND,"","Triage IOA",i,"",-1);
}

current_time.setTime(current_time.getTime() + 3600 * 1000);
traceln(current_time.toString());

]]></StartupCode>
			<Generic>false</Generic>
