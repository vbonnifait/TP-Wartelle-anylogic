							<Value Class="CodeValue">
								<Code><![CDATA[agent.id = v_current_id;
v_current_id++;
agent.ta = date();
traceln("Arrival of patient " + agent.id + " at " + agent.ta);
agent.p_circuit_id = 1;
int resultat = bernoulli(0.5);
if(resultat == 0) {
	agent.p_circuit_id = 2;
} ]]></Code>
