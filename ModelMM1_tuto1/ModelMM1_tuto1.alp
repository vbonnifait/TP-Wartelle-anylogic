							<Value Class="CodeValue">
								<Code><![CDATA[agent.td = date();
traceln("Departure of patient " + agent.id + " at " + agent.td);

// Définir le pattern
SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd HH:mm:ss");

// Transformer la date
String ta_str = sdf.format(agent.ta);
String td_str = sdf.format(agent.td);

c_output_lines.add(agent.id + ";" + 
	ta_str + ";" + 
	td_str);]]></Code>
